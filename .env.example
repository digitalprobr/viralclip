# ==============================================================================
# 🔐 CONFIGURATION DES CLÉS API
# Renommez ce fichier en `.env` et remplissez vos propres clés.
# ==============================================================================

# 1. Groq (Recommandé pour la transcription Whisper très rapide)
GROQ_API_KEY=your_groq_api_key_here

# 2. Google Gemini (Moteur d'analyse par défaut)
GEMINI_API_KEY=your_gemini_api_key_here

# 3. DeepSeek (Excellent fallback d'analyse)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 4. Alibaba Qwen (Génial pour le SEO multicompte)
ALIBABA_API_KEY=your_alibaba_api_key_here

# Autres variables
TELEGRAM_BOT_TOKEN=

# (Optionnel) Hugging Face pour Hébergement de modèles Locaux / API Serverless
HF_TOKEN=
