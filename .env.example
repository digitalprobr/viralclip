# ==============================================================================
# 🎬 AUTOCLIP AI — Environment Configuration
# Copy this file to `.env` and fill in your API keys.
# ==============================================================================

# ── AI Engines (at least one required) ──────────────────
GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── Authentication ──────────────────────────────────────
# Secret key for JWT signing (generate with: openssl rand -hex 32)
AUTH_SECRET_KEY=your_random_secret_key_here

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3001

# ── Infrastructure (auto-configured by Docker Compose) ──
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/autoclip
REDIS_URL=redis://redis:6379/0

# ── Optional ────────────────────────────────────────────
# Hugging Face token (for Whisper model downloads)
HF_TOKEN=
